# Database (Aurora Serverless v2)
DATABASE_URL=postgresql://user:pass@host/skillshub?sslmode=require

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/callback

# Session
SESSION_SECRET=at-least-32-characters-long-random-string

# Encryption (for GitHub token encryption at rest)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=64-hex-chars-for-aes-256

# GitHub API (for repo import)
GITHUB_TOKEN=

# App
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform BSC address for 5% donation fee
NEXT_PUBLIC_PLATFORM_BSC_ADDRESS=0x0000000000000000000000000000000000000000
